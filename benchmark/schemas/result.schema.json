{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codeflow.local/schemas/benchmark-result.schema.json",
  "title": "CodeFlow Benchmark Result",
  "type": "object",
  "required": ["id", "dataset", "method", "status", "checks_passed"],
  "additionalProperties": true,
  "properties": {
    "run_id": {
      "type": ["string", "null"]
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string",
      "enum": ["checks_only", "raw_mini", "codeflow_basic", "codeflow_full"]
    },
    "source_repo": {
      "type": ["string", "null"]
    },
    "workspace": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "checks_passed": {
      "type": "boolean"
    },
    "attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "repair_rounds": {
      "type": "integer",
      "minimum": 0
    },
    "risk_level": {
      "type": "string"
    },
    "review_risk_level": {
      "type": "string"
    },
    "unsafe_diff": {
      "type": "boolean"
    },
    "runtime_seconds": {
      "type": "number",
      "minimum": 0
    },
    "error_type": {
      "type": ["string", "null"]
    },
    "error_category": {
      "type": ["string", "null"]
    },
    "error": {
      "type": ["string", "null"]
    },
    "model": {
      "type": ["string", "null"]
    },
    "provider": {
      "type": ["string", "null"]
    },
    "prompt_tokens": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "completion_tokens": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "total_tokens": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "estimated_cost_usd": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "patch_stats": {
      "type": "object",
      "required": ["files", "additions", "deletions"],
      "additionalProperties": true,
      "properties": {
        "files": {
          "type": "integer",
          "minimum": 0
        },
        "additions": {
          "type": "integer",
          "minimum": 0
        },
        "deletions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "artifact_paths": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
